# Flask設定
FLASK_APP=app.main:create_app

# Flask環境: testing | development | staging | production
FLASK_ENV=development

# セキュリティ
SECRET_KEY=your-secret-key-change-in-production

# -----------------------------------------------
# SQL Server接続設定 (staging / production のみ)
# development の場合は設定不要 (SQLite を使用)
# -----------------------------------------------
DB_SERVER=your-sql-server-host
DB_NAME=your-database-name
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# -----------------------------------------------
# マスタDB SQL Server接続設定 (staging / production のみ)
# mst_account, mst_cost_center, mst_district, mst_wbs, mst_User が対象
# development / testing の場合は設定不要 (SQLite master.db を使用)
# -----------------------------------------------
MASTER_DB_SERVER=your-master-sql-server-host
MASTER_DB_NAME=your-master-database-name
MASTER_DB_USERNAME=your-master-db-username
MASTER_DB_PASSWORD=your-master-db-password

# -----------------------------------------------
# ログ設定
# -----------------------------------------------
LOG_LEVEL=INFO
